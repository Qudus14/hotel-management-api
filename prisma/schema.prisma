generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String  @id @default(uuid())
  name            String
  email           String  @unique
  password        String
  role            Role    @default(customer)
  address         String?
  phoneNumber     String?
  isActive        Boolean @default(true)
  isEmailVerified Boolean @default(false)
  profileImage    String?

  // ✅ ADD WALLET SUPPORT
  walletBalance Float               @default(1000000)
  walletLedger  WalletTransaction[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Room {
  id         Int    @id @default(autoincrement())
  roomNumber String @unique
  floor      Int? // Added

  type     RoomType
  capacity Int      @default(1) // Added
  bedType  String? // Added (e.g., King, Twin)

  price  Decimal    @db.Decimal(10, 2)
  status RoomStatus @default(available)

  // New "Senior Dev" fields
  amenities   String[] // Stored as an array in Postgres
  images      String[] // Stored as an array of URLs
  description String?  @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Booking {
  id String @id @default(uuid())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String
  room   Room   @relation(fields: [roomId], references: [id])
  roomId Int

  // Core Dates
  checkInDate    DateTime
  checkOutDate   DateTime
  actualCheckIn  DateTime? // Nullable: Filled when they walk in
  actualCheckOut DateTime? // Nullable: Filled when they leave

  // Financials
  totalPrice    Decimal       @db.Decimal(12, 2)
  depositAmount Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(PENDING)

  // Operational Fields
  status          BookingStatus @default(pending)
  numberOfGuests  Int           @default(1)
  specialRequests String?       @db.Text

  payments           Payment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  walletTransactions WalletTransaction[]
}

model Payment {
  id            String        @id @default(uuid())
  amount        Decimal       @db.Decimal(12, 2) // Supports up to 9,999,999,999.99
  currency      String        @default("NGN")
  status        PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod

  // IDs for Reconcilliation
  transactionId String? @unique // Nullable initially if payment hasn't started
  reference     String  @unique // Your internal ID (e.g., "PAY-2026-001")

  // Relations
  booking   Booking @relation(fields: [bookingId], references: [id])
  bookingId String

  // Audit Trail (The "Senior Dev" Safety Net)
  gatewayResponse Json? // Stores the full payload from Stripe/Paystack
  failureReason   String? // Detailed error message if status is FAILED
  paidAt          DateTime? // The actual moment the gateway confirmed success

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([transactionId])
}

// ✅ ADD WALLET TRANSACTION MODEL
model WalletTransaction {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  amount        Float
  type          TransactionType
  balanceBefore Float
  balanceAfter  Float

  description String
  reference   String @unique // For idempotency

  // Optional relation to booking/payment
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  fundedBy      String? // Admin user ID who funded this
  fundingReason String? // Why the credits were added

  status TransactionStatus @default(COMPLETED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([reference])
}

// ✅ ADD IDEMPOTENCY KEY MODEL (Race Condition Protection)
model IdempotencyKey {
  id         String            @id @default(uuid())
  key        String            @unique
  resourceId String? // ID of created resource (booking, payment, etc.)
  status     IdempotencyStatus @default(PENDING)
  response   Json? // Store the original response
  expiresAt  DateTime

  createdAt DateTime @default(now())

  @@index([expiresAt])
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  COMPLETED
  FAILED
  REVERSED
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED
}

// --- ENUMS STAY THE SAME ---

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  BANK_TRANSFER
  CASH
}

enum BookingStatus {
  confirmed
  pending
  cancelled
}

enum RoomType {
  single
  double
  suite
  deluxe
  family
  presidential
  standard
  economy
  luxury
}

enum RoomStatus {
  available
  occupied
  maintenance
  reserved
  cleaning
  out_of_service @map("out of service")
}

enum Role {
  admin
  staff
  customer
}
