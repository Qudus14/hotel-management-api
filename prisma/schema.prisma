generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String  @id @default(uuid())
  name            String
  email           String  @unique
  password        String
  role            Role    @default(customer)
  address         String?
  phoneNumber     String?
  isActive        Boolean @default(true)
  isEmailVerified Boolean @default(false)
  profileImage    String?

  walletBalance Float               @default(0)
  walletLedger  WalletTransaction[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       Booking[]
  flightBookings FlightBooking[]
}

model Room {
  id         Int    @id @default(autoincrement())
  roomNumber String @unique
  floor      Int?

  type     RoomType
  capacity Int      @default(1)
  bedType  String?

  price  Decimal    @db.Decimal(10, 2)
  status RoomStatus @default(available)

  amenities   String[]
  images      String[]
  description String?  @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Booking {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String
  room   Room   @relation(fields: [roomId], references: [id])
  roomId Int

  checkInDate    DateTime
  checkOutDate   DateTime
  actualCheckIn  DateTime?
  actualCheckOut DateTime?

  totalPrice    Decimal       @db.Decimal(12, 2)
  depositAmount Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(PENDING)

  status          BookingStatus @default(pending)
  numberOfGuests  Int           @default(1)
  specialRequests String?       @db.Text
  cancelledAt     DateTime?

  payments           Payment[]
  walletTransactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String        @id @default(uuid())
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("NGN")
  status        PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod

  transactionId String? @unique
  reference     String  @unique

  booking   Booking @relation(fields: [bookingId], references: [id])
  bookingId String

  gatewayResponse Json?
  failureReason   String?
  paidAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([transactionId])
}

model WalletTransaction {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  amount        Float
  type          TransactionType
  balanceBefore Float
  balanceAfter  Float

  description String
  reference   String @unique

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  fundedBy      String?
  fundingReason String?

  status TransactionStatus @default(COMPLETED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([reference])
}

model IdempotencyKey {
  id         String            @id @default(uuid())
  key        String            @unique
  resourceId String?
  status     IdempotencyStatus @default(PENDING)
  response   Json?
  expiresAt  DateTime

  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model FlightBooking {
  id String @id @default(uuid())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String

  segments BookingSegment[]

  // Link to Add-Ons (Baggage, Meals)
  addOns BookingAddOn[]

  totalPrice Decimal             @default(0) @db.Decimal(12, 2)
  status     FlightBookingStatus @default(BOOKED)

  // For Check-in logic
  qrCode          String? @db.Text
  boardingPassUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seats     Seat[]
  flight    Flight?  @relation(fields: [flightId], references: [id])
  flightId  String?
}

model Seat {
  id          String  @id @default(uuid())
  flightId    String // Connects to the Flight model
  seatNumber  String // E.g., "12A"
  class       String // E.g., "Economy", "Business", "First"
  isAvailable Boolean @default(true)
  price       Decimal @db.Decimal(10, 2)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  flightBooking   FlightBooking?   @relation(fields: [flightBookingId], references: [id])
  flight          Flight           @relation(fields: [flightId], references: [id])
  flightBookingId String?
  bookingSegments BookingSegment[]

  @@unique([flightId, seatNumber])
}

model Flight {
  id               String       @id @default(uuid())
  flightNumber     String       @unique
  departureAirport String
  arrivalAirport   String
  departureTime    DateTime
  arrivalTime      DateTime
  price            Decimal      @db.Decimal(10, 2)
  status           FlightStatus @default(SCHEDULED)

  seats    Seat[] // Relation to Seats
  bookings FlightBooking[] // Relation to Bookings

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bookingSegments BookingSegment[]
}

model Airplane {
  id         String @id @default(uuid())
  model      String
  tailNumber String
  totalSeats Int
  airline    String
  capacity   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookingSegment {
  id              String        @id @default(uuid())
  flightBookingId String
  flightBooking   FlightBooking @relation(fields: [flightBookingId], references: [id])

  flightId String
  flight   Flight @relation(fields: [flightId], references: [id])

  seatId String
  seat   Seat   @relation(fields: [seatId], references: [id])
}

model BookingAddOn {
  id              String        @id @default(uuid())
  flightBookingId String
  flightBooking   FlightBooking @relation(fields: [flightBookingId], references: [id])

  addOnId String
  addOn   AddOn  @relation(fields: [addOnId], references: [id])

  quantity Int @default(1)
}

model AddOn {
  id    String    @id @default(uuid())
  type  AddOnType // Uses your existing Enum
  name  String // e.g., "Extra 20kg Bag"
  price Decimal   @db.Decimal(10, 2)

  // This connects back to the join table
  bookings BookingAddOn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== ENUMS ====================
enum FlightStatus {
  SCHEDULED
  DELAYED
  BOARDING
  DEPARTED
  ARRIVED
  CANCELLED
}

enum AddOnType {
  BAGGAGE
  MEAL
  WIFI
  PRIORITY_BOARDING
}

enum FlightBookingStatus {
  BOOKED
  PAID
  CANCELLED
  BOARDED
}

enum Role {
  admin
  staff
  customer
}

enum RoomType {
  single
  double
  suite
  deluxe
  family
  presidential
  standard
  economy
  luxury
}

enum RoomStatus {
  available
  occupied
  maintenance
  reserved
  cleaning
  out_of_service @map("out of service")
}

enum BookingStatus {
  pending
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  BANK_TRANSFER
  CASH
  WALLET
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  COMPLETED
  FAILED
  REVERSED
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED
}
